NODE_ENV=production
PORT=10000

# MongoDB Atlas connection string (include your db name, e.g. /eventora before the ?)
MONGO_URI=

# JWT
JWT_SECRET=
JWT_EXPIRE=30d

# Google OAuth
GOOGLE_CLIENT_ID=

# Set once your frontend is deployed (for CORS)
FRONTEND_URL=

# Optional - only needed if sending emails via SendGrid
SENDGRID_API_KEY=
EMAIL_FROM=

# Optional - has a working demo key hardcoded as fallback
TMDB_API_KEY=